# OpenAI-compatible endpoint used by DeepSeek, Gemini-compatible gateways, Kimi, etc.
URL=https://your-openai-compatible-endpoint/v1
KEY=your_api_key

# Models used by the three-stage pipeline.
EVOLVE_MODEL=your-evolver-model
VERIFY_MODEL=your-verifier-model

# Optional: Qwen endpoints that require Basic auth.
API_AK=your_qwen_access_key
API_SK=your_qwen_secret_key
QWEN_THINKING_URL=https://your-qwen-thinking-endpoint/v1
QWEN_INSTRUCT_URL=https://your-qwen-instruct-endpoint/v1
